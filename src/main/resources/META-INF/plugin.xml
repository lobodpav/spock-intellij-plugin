<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
    <id>io.github.lobodpav.spock</id>
    <name>Spock framework support</name>
    <vendor>Pavel Lobodinský</vendor>
    <description>
        <![CDATA[
            <p>
                Provides support for the amazing <a href="https://spockframework.org">Spock testing framework</a>.
            </p>
            <p>
                Features:
            </p>
            <ul>
                <li>Validation of block names, their order and completeness (e.g. invalid blocks, missing `then` blocks, etc.)</li>
                <li>Creation of new Spock Specification using a New File action</li>
            </ul>
            <p>
                Stay tuned for more features.
            </li>
        ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.intellij.groovy</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType implementationClass="io.github.lobodpav.spock.type.SpecificationFileType"
                  language="Groovy" order="first" name="SpockSpecification"
                  extensions="spock"/>

        <iconProvider implementation="io.github.lobodpav.spock.icon.SpecificationIconProvider"/>
    </extensions>

    <actions>
        <action id="io.github.lobodpav.spock.action.NewSpockSpecificationAction"
                class="io.github.lobodpav.spock.action.NewSpockSpecificationAction"
                text="Spock Specification" description="Creates a new Spock Specification">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="Groovy.NewClass"/>
        </action>
    </actions>

    <xi:include href="plugin-inspections.xml" xpointer="xpointer(/idea-plugin/*)"/>
    <xi:include href="plugin-templates.xml"   xpointer="xpointer(/idea-plugin/*)"/>
</idea-plugin>
